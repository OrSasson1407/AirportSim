<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rendering="clr-namespace:AirportSim.Client.Rendering"
             x:Class="AirportSim.Client.Views.SimulationView">

    <UserControl.Styles>

        <!-- ── Sidebar section label ───────────────────────────────────── -->
        <Style Selector="TextBlock.SectionLabel">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AtcTextMuted}"/>
            <Setter Property="LetterSpacing" Value="2"/>
        </Style>

        <!-- ── Standard sidebar button ────────────────────────────────── -->
        <Style Selector="Button.SidebarBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AtcText}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.SidebarBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

        <!-- ── Speed pill button ──────────────────────────────────────── -->
        <Style Selector="Button.SpeedBtn">
            <Setter Property="Background" Value="{DynamicResource AtcSurface1}"/>
            <Setter Property="Foreground" Value="{DynamicResource AtcTextSub}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AtcBorderSubtle}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.SpeedBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

        <!-- ── Panel header label ──────────────────────────────────────── -->
        <Style Selector="TextBlock.PanelHeader">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Foreground" Value="{DynamicResource AtcPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── Panel close button ─────────────────────────────────────── -->
        <Style Selector="Button.PanelClose">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AtcTextMuted}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.PanelClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="256, *" RowDefinitions="*, Auto">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 0 — Sidebar                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource AtcSidebar}"
                BorderBrush="{DynamicResource AtcBorderLine}"
                BorderThickness="0,0,1,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="0" Margin="0,0,0,8">

                    <!-- Branding header -->
                    <Border Padding="16,18,16,14"
                            BorderBrush="{DynamicResource AtcBorderSubtle}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="ATC TERMINAL"
                                           FontSize="15" FontWeight="Black"
                                           Foreground="{DynamicResource AtcPrimary}"
                                           LetterSpacing="3"/>
                                <TextBlock Text="SIMULATION SYSTEM v2"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}"
                                           LetterSpacing="1.5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Time & weather widget -->
                    <Border Margin="12,14,12,0"
                            Background="{DynamicResource AtcSurface0}"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1"
                            Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionLabel" Text="LOCAL TIME — LLBG"/>
                            <TextBlock x:Name="TimeText"
                                       Foreground="{DynamicResource AtcText}"
                                       FontSize="26" FontWeight="Bold"
                                       FontFamily="Consolas"/>
                            <Border Height="1" Background="{DynamicResource AtcBorderSubtle}" Margin="0,2,0,2"/>
                            <TextBlock x:Name="WeatherText"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       FontSize="11" FontWeight="SemiBold"
                                       LetterSpacing="0.5"/>
                        </StackPanel>
                    </Border>

                    <!-- Playback controls -->
                    <StackPanel Margin="12,16,12,0" Spacing="8">
                        <TextBlock Classes="SectionLabel" Text="PLAYBACK SPEED" Margin="2,0,0,2"/>
                        <Grid ColumnDefinitions="32,*,*,*,32" HorizontalAlignment="Stretch">
                            <Button Grid.Column="0" Content="«" Click="SpeedDown_Click" Classes="SpeedBtn" ToolTip.Tip="Speed down"/>
                            <Button Grid.Column="1" Content="1×"  Click="Speed1x_Click"  Classes="SpeedBtn" Margin="3,0,0,0"/>
                            <Button Grid.Column="2" Content="10×" Click="Speed60x_Click" Classes="SpeedBtn" Margin="3,0,0,0"/>
                            <Button Grid.Column="3" Content="60×" Click="Speed60x_Click" Classes="SpeedBtn" Margin="3,0,0,0"/>
                            <Button Grid.Column="4" Content="»"  Click="SpeedUp_Click"  Classes="SpeedBtn" ToolTip.Tip="Speed up" Margin="3,0,0,0"/>
                        </Grid>
                        <Button x:Name="PauseButton"
                                Content="⏸  PAUSE SIMULATION"
                                Click="Pause_Click"
                                Background="{DynamicResource AtcSurface2}"
                                Foreground="{DynamicResource AtcWarning}"
                                BorderBrush="{DynamicResource AtcWarningDim}"
                                BorderThickness="1" CornerRadius="6"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                FontWeight="Bold" FontSize="11" Padding="10,10"/>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource AtcBorderSubtle}" Margin="12,16,12,0"/>

                    <!-- Map overlays -->
                    <StackPanel Margin="12,14,12,0" Spacing="2">
                        <TextBlock Classes="SectionLabel" Text="MAP OVERLAYS" Margin="2,0,0,6"/>

                        <Button x:Name="ToggleRadarButton" Click="ToggleRadar_Click" Classes="SidebarBtn">
                            <Button.Content>
                                <Grid ColumnDefinitions="4,28,*">
                                    <Border Grid.Column="0" Width="3" Height="16" CornerRadius="2" Background="{DynamicResource AtcPrimary}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="📡" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Radar View" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Button.Content>
                        </Button>

                        <Button x:Name="ToggleQueueButton" Click="ToggleQueue_Click" Classes="SidebarBtn">
                            <Button.Content>
                                <Grid ColumnDefinitions="4,28,*">
                                    <Border Grid.Column="0" Width="3" Height="16" CornerRadius="2" Background="{DynamicResource AtcAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="☰" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Flight Queue" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Button.Content>
                        </Button>

                        <Button x:Name="ToggleAlertsButton" Click="ToggleAlerts_Click" Classes="SidebarBtn">
                            <Button.Content>
                                <Grid ColumnDefinitions="4,28,*">
                                    <Border Grid.Column="0" Width="3" Height="16" CornerRadius="2" Background="{DynamicResource AtcDanger}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="🔔" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="System Alerts" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Button.Content>
                        </Button>

                        <Button x:Name="ToggleDashboardButton" Click="ToggleDashboard_Click" Classes="SidebarBtn">
                            <Button.Content>
                                <Grid ColumnDefinitions="4,28,*">
                                    <Border Grid.Column="0" Width="3" Height="16" CornerRadius="2" Background="{DynamicResource AtcSuccess}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="📊" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Live Dashboard" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Button.Content>
                        </Button>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource AtcBorderSubtle}" Margin="12,14,12,0"/>

                    <!-- Environmental controls -->
                    <StackPanel Margin="12,14,12,0" Spacing="8">
                        <TextBlock Classes="SectionLabel" Text="ENVIRONMENT" Margin="2,0,0,2"/>
                        <Button Content="🌤  Refresh Weather" Click="Weather_Click" Classes="SidebarBtn" FontSize="12"/>
                    </StackPanel>

                    <!-- Emergency zone -->
                    <Border Margin="12,20,12,0"
                            Background="{DynamicResource AtcDangerDim}"
                            BorderBrush="{DynamicResource AtcDanger}"
                            BorderThickness="1" CornerRadius="8" Padding="10,10">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionLabel" Text="⚠  EMERGENCY CONTROL"
                                       Foreground="{DynamicResource AtcDanger}"/>
                            <Button Content="🚨  DECLARE EMERGENCY"
                                    Click="Emergency_Click"
                                    Background="{DynamicResource AtcDanger}"
                                    Foreground="White" CornerRadius="6"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontWeight="Bold" FontSize="11" Padding="10,10"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 1 — Main Canvas & Floating Panels                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="0" Background="{DynamicResource AtcBackground}" ClipToBounds="True">
            <Grid>
                <!-- Radar Scope Background Elements -->
                <Border BorderBrush="{DynamicResource AtcRadarGrid}" BorderThickness="1" Opacity="0.15" CornerRadius="1000" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Height="400"/>
                <Border BorderBrush="{DynamicResource AtcRadarGrid}" BorderThickness="1" Opacity="0.10" CornerRadius="1000" HorizontalAlignment="Center" VerticalAlignment="Center" Width="800" Height="800"/>
                <Border BorderBrush="{DynamicResource AtcRadarGrid}" BorderThickness="1" Opacity="0.05" CornerRadius="1000" HorizontalAlignment="Center" VerticalAlignment="Center" Width="1200" Height="1200"/>
                
                <Border Width="1" Background="{DynamicResource AtcRadarGrid}" Opacity="0.15" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
                <Border Height="1" Background="{DynamicResource AtcRadarGrid}" Opacity="0.15" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

                <rendering:AirportCanvas x:Name="SimCanvas" />

                <!-- ── ALERT PANEL (top-right) ─────────────────────────────── -->
                <Border x:Name="AlertPanel"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,16,0"
                        Width="310" MaxHeight="320"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto, *">

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <TextBlock Grid.Column="0" Classes="PanelHeader" Text="SYSTEM ALERTS"/>
                                <!-- Live count badge -->
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AtcDangerDim}"
                                        BorderBrush="{DynamicResource AtcDanger}"
                                        BorderThickness="1"
                                        CornerRadius="10" Padding="6,1"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="AlertCountBadge"
                                               Text="0"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcDanger}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        x:Name="ClearAlertsButton"
                                        Content="✕"
                                        Classes="PanelClose"
                                        Click="ClearAlerts_Click"/>
                            </Grid>
                        </Border>

                        <!-- Alert rows -->
                        <ScrollViewer Grid.Row="1"
                                      x:Name="AlertScroller"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AlertList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,0,0,0"
                                                BorderThickness="0,0,0,1"
                                                BorderBrush="{DynamicResource AtcBorderSubtle}">
                                            <Grid ColumnDefinitions="3, *">
                                                <!-- Severity stripe — colored in code-behind via tag -->
                                                <Border Grid.Column="0"
                                                        Width="3"
                                                        Background="{DynamicResource AtcTextMuted}"
                                                        x:Name="AlertStripe"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AtcText}"
                                                           TextWrapping="Wrap"
                                                           Padding="10,8,10,8"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── QUEUE PANEL (top-left) ──────────────────────────────── -->
                <Border x:Name="QueuePanel"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="16,16,0,0"
                        Width="260" MaxHeight="360"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto, *">

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" Classes="PanelHeader" Text="FLIGHT QUEUE"/>
                                <!-- Arrival/departure legend -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{DynamicResource AtcSuccess}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="ARR" FontSize="9"
                                                   Foreground="{DynamicResource AtcTextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{DynamicResource AtcPrimary}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="DEP" FontSize="9"
                                                   Foreground="{DynamicResource AtcTextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Flight rows -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="QueueList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1"
                                                BorderBrush="{DynamicResource AtcBorderSubtle}">
                                            <Grid ColumnDefinitions="3, *">
                                                <!-- Direction stripe: green=arrival, cyan=departure -->
                                                <Border Grid.Column="0" Width="3" Background="{DynamicResource AtcTextMuted}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="11"
                                                           FontFamily="Consolas"
                                                           Foreground="{DynamicResource AtcText}"
                                                           Padding="10,8,10,8"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── EMERGENCY BANNER (center top) ──────────────────────── -->
                <Border x:Name="EmergencyBanner"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,12,0,0"
                        Padding="28,12,28,12"
                        Background="{DynamicResource AtcDangerDim}"
                        BorderBrush="{DynamicResource AtcDanger}"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <!-- Pulse dot -->
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="{DynamicResource AtcDanger}"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="EmergencyText"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AtcDanger}"
                                   LetterSpacing="1"
                                   VerticalAlignment="Center"
                                   Text="🚨 EMERGENCY DECLARED — MAYDAY"/>
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="{DynamicResource AtcDanger}"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── AIRCRAFT INFO PANEL (bottom-left) ──────────────────── -->
                <Border x:Name="AircraftInfoPanel"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="16,0,0,16"
                        Width="260"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto, Auto">

                        <!-- Header: flight ID + phase pill -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock x:Name="InfoFlightId"
                                           Grid.Column="0"
                                           Text="—"
                                           FontSize="16" FontWeight="Bold"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource AtcSuccess}"
                                           VerticalAlignment="Center"/>
                                <!-- Phase pill -->
                                <Border Grid.Column="1"
                                        x:Name="InfoPhasePill"
                                        Background="{DynamicResource AtcInfoDim}"
                                        BorderBrush="{DynamicResource AtcInfo}"
                                        BorderThickness="1"
                                        CornerRadius="10" Padding="8,3"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="InfoPhase"
                                               Text="—"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcInfo}"
                                               LetterSpacing="0.5"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Data rows -->
                        <StackPanel Grid.Row="1" Margin="12,10,12,14" Spacing="7">

                            <Grid ColumnDefinitions="*, *">
                                <TextBlock Text="TYPE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}" LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoType" Grid.Column="1"
                                           Text="—" FontSize="12"
                                           Foreground="{DynamicResource AtcText}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderSubtle}"/>

                            <Grid ColumnDefinitions="*, *">
                                <TextBlock Text="ALTITUDE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}" LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoAlt" Grid.Column="1"
                                           Text="—" FontSize="12"
                                           Foreground="{DynamicResource AtcText}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderSubtle}"/>

                            <Grid ColumnDefinitions="*, *">
                                <TextBlock Text="SPEED" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}" LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoSpeed" Grid.Column="1"
                                           Text="—" FontSize="12"
                                           Foreground="{DynamicResource AtcText}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderSubtle}"/>

                            <!-- Gate row — highlighted when assigned -->
                            <Grid ColumnDefinitions="*, *">
                                <TextBlock Text="GATE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}" LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoGate" Grid.Column="1"
                                           Text="—" FontSize="12"
                                           Foreground="{DynamicResource AtcPrimary}"
                                           HorizontalAlignment="Right" FontWeight="Bold"
                                           FontFamily="Consolas"/>
                            </Grid>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── DASHBOARD PANEL (bottom-right) ─────────────────────── -->
                <Border x:Name="DashboardPanel"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,16,16"
                        Width="360"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto">

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" Classes="PanelHeader" Text="LIVE STATS DASHBOARD"/>
                                <Button Grid.Column="1" Content="✕"
                                        Classes="PanelClose"
                                        Click="ToggleDashboard_Click"/>
                            </Grid>
                        </Border>

                        <!-- Traffic graph -->
                        <Border Grid.Row="1"
                                Padding="14,12,14,8"
                                BorderBrush="{DynamicResource AtcBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel" Text="TRAFFIC VOLUME — LAST 10 MIN"/>
                                <Border Background="{DynamicResource AtcSurface1}"
                                        CornerRadius="4" Padding="2">
                                    <Canvas x:Name="TrafficGraphCanvas"
                                            Height="65"
                                            ClipToBounds="True"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Go-arounds by weather -->
                        <Border Grid.Row="2"
                                Padding="14,10,14,10"
                                BorderBrush="{DynamicResource AtcBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel" Text="GO-AROUNDS BY WEATHER"/>
                                <ItemsControl x:Name="GoAroundList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Grid ColumnDefinitions="*, Auto" Margin="0,3">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AtcTextSub}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource AtcAccent}"
                                                           FontFamily="Consolas" FontWeight="Bold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Runway utilization -->
                        <Border Grid.Row="3" Padding="14,10,14,16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel" Text="RUNWAY UTILIZATION"/>

                                <!-- 28L Arrivals -->
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="28L  ARRIVALS"
                                               FontSize="10" Foreground="{DynamicResource AtcTextSub}"/>
                                    <TextBlock x:Name="Rwy0Pct" Grid.Column="1"
                                               Text="0%" FontSize="10"
                                               Foreground="{DynamicResource AtcRunwayArrival}"
                                               FontFamily="Consolas"/>
                                </Grid>
                                <Border Height="8" CornerRadius="4"
                                        Background="{DynamicResource AtcSurface1}">
                                    <Border x:Name="Rwy0Bar"
                                            HorizontalAlignment="Left"
                                            Height="8" Width="0" CornerRadius="4"
                                            Background="{DynamicResource AtcRunwayArrival}"/>
                                </Border>

                                <!-- 28R Departures -->
                                <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                                    <TextBlock Grid.Column="0" Text="28R  DEPARTURES"
                                               FontSize="10" Foreground="{DynamicResource AtcTextSub}"/>
                                    <TextBlock x:Name="Rwy1Pct" Grid.Column="1"
                                               Text="0%" FontSize="10"
                                               Foreground="{DynamicResource AtcRunwayDeparture}"
                                               FontFamily="Consolas"/>
                                </Grid>
                                <Border Height="8" CornerRadius="4"
                                        Background="{DynamicResource AtcSurface1}">
                                    <Border x:Name="Rwy1Bar"
                                            HorizontalAlignment="Left"
                                            Height="8" Width="0" CornerRadius="4"
                                            Background="{DynamicResource AtcRunwayDeparture}"/>
                                </Border>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM STATUS BAR                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource AtcSurface0}"
                BorderBrush="{DynamicResource AtcBorderLine}"
                BorderThickness="0,1,0,0"
                Padding="14,7">
            <Grid ColumnDefinitions="*, Auto">

                <!-- Left — runway state chips -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">

                    <!-- 28L Arrivals -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border x:Name="Rwy28LDot"
                                    Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AtcRunwayArrival}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="28L" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcTextSub}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="Rwy28LStatus"
                                       Text="CLEAR" FontSize="10"
                                       Foreground="{DynamicResource AtcRunwayArrival}"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 28R Departures -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border x:Name="Rwy28RDot"
                                    Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AtcRunwayDeparture}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="28R" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcTextSub}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="Rwy28RStatus"
                                       Text="CLEAR" FontSize="10"
                                       Foreground="{DynamicResource AtcRunwayDeparture}"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Width="1" Height="14"
                            Background="{DynamicResource AtcBorderLine}"
                            VerticalAlignment="Center" Margin="2,0"/>

                    <!-- Active aircraft -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="✈" FontSize="11"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipAircraft"
                                       Text="0" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="AC" FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Arrivals today -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↓" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcSuccess}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipArrivals"
                                       Text="0" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="ARR" FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Departures today -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↑" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipDepartures"
                                       Text="0" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="DEP" FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Go-arounds -->
                    <Border Background="{DynamicResource AtcSurface2}"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1" CornerRadius="5"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↩" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcWarning}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipGoArounds"
                                       Text="0" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="G/A" FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Right — server status -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <TextBlock Text="SERVER" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource AtcTextMuted}"
                               LetterSpacing="1.5"
                               VerticalAlignment="Center"/>
                    <Border x:Name="ConnectionIndicator"
                            Width="8" Height="8" CornerRadius="4"
                            Background="Gray"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Server connection"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>