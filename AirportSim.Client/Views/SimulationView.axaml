<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rendering="clr-namespace:AirportSim.Client.Rendering"
             x:Class="AirportSim.Client.Views.SimulationView">

    <UserControl.Styles>

        <!-- ── Section label ──────────────────────────────────────────────── -->
        <Style Selector="TextBlock.SectionLabel">
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{DynamicResource AtcTextMuted}"/>
            <Setter Property="LetterSpacing" Value="2.5"/>
        </Style>

        <!-- ── Sidebar nav button ─────────────────────────────────────────── -->
        <Style Selector="Button.SidebarBtn">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="{DynamicResource AtcTextSub}"/>
            <Setter Property="CornerRadius"            Value="6"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                 Value="10,10"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SidebarBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

        <!-- ── Speed pill button ──────────────────────────────────────────── -->
        <Style Selector="Button.SpeedBtn">
            <Setter Property="Background"              Value="{DynamicResource AtcSurface2}"/>
            <Setter Property="Foreground"              Value="{DynamicResource AtcTextSub}"/>
            <Setter Property="CornerRadius"            Value="5"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                 Value="4,8"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="BorderBrush"             Value="{DynamicResource AtcBorderSubtle}"/>
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="FontWeight"              Value="Bold"/>
        </Style>
        <Style Selector="Button.SpeedBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

        <!-- ── Speed pill ACTIVE state ────────────────────────────────────── -->
        <Style Selector="Button.SpeedBtnActive">
            <Setter Property="Background"   Value="{DynamicResource AtcPrimaryDim}"/>
            <Setter Property="Foreground"   Value="{DynamicResource AtcPrimary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource AtcBorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding"      Value="4,8"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="Bold"/>
        </Style>

        <!-- ── Floating panel header label ───────────────────────────────── -->
        <Style Selector="TextBlock.PanelHeader">
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="FontWeight"    Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Foreground"    Value="{DynamicResource AtcPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── Panel close button ─────────────────────────────────────────── -->
        <Style Selector="Button.PanelClose">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource AtcTextMuted}"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CornerRadius"    Value="4"/>
        </Style>
        <Style Selector="Button.PanelClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AtcSurface3}"/>
        </Style>

        <!-- ── Status bar chip ────────────────────────────────────────────── -->
        <Style Selector="Border.StatusChip">
            <Setter Property="Background"      Value="{DynamicResource AtcSurface2}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AtcBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="Padding"         Value="8,5"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="264,*" RowDefinitions="*,Auto">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 0 — SIDEBAR                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource AtcSidebar}"
                BorderBrush="{DynamicResource AtcBorderLine}"
                BorderThickness="0,0,1,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="0" Margin="0,0,0,12">

                    <!-- ── Branding header ───────────────────────────── -->
                    <Border Padding="16,18,16,14"
                            BorderBrush="{DynamicResource AtcBorderSubtle}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Spacing="3">
                            <TextBlock Text="ATC TERMINAL"
                                       FontSize="14" FontWeight="Black"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       LetterSpacing="4"/>
                            <TextBlock Text="SIMULATION SYSTEM  v3"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       LetterSpacing="2"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Time & weather widget ─────────────────────── -->
                    <Border Margin="12,14,12,0"
                            Background="{DynamicResource AtcSurface0}"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource AtcBorderLine}"
                            BorderThickness="1"
                            Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionLabel" Text="LOCAL TIME — LLBG"/>

                            <!-- Clock — large, monospace, bold -->
                            <TextBlock x:Name="TimeText"
                                       Foreground="{DynamicResource AtcText}"
                                       FontSize="30" FontWeight="Black"/>

                            <!-- Date row -->
                            <TextBlock x:Name="DateText"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       FontSize="10" FontWeight="Bold"
                                       LetterSpacing="1"/>

                            <Border Height="1"
                                    Background="{DynamicResource AtcBorderSubtle}"
                                    Margin="0,2,0,2"/>

                            <!-- Weather + RVR row -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock x:Name="WeatherText" Grid.Column="0"
                                           Foreground="{DynamicResource AtcPrimary}"
                                           FontSize="11" FontWeight="SemiBold"
                                           LetterSpacing="0.5"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AtcAccentDim}"
                                        BorderBrush="{DynamicResource AtcAccent}"
                                        BorderThickness="1"
                                        CornerRadius="4" Padding="6,2"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="RVR"
                                                   FontSize="8" FontWeight="Bold"
                                                   Foreground="{DynamicResource AtcTextMuted}"
                                                   LetterSpacing="1"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="RvrValueText"
                                                   Text="10+ km"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource AtcAccent}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Playback controls ──────────────────────────── -->
                    <StackPanel Margin="12,16,12,0" Spacing="8">
                        <TextBlock Classes="SectionLabel" Text="PLAYBACK SPEED" Margin="2,0,0,2"/>

                        <!-- Speed pill group -->
                        <Grid ColumnDefinitions="28,*,*,*,28" HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="«" Click="SpeedDown_Click"
                                    Classes="SpeedBtn"
                                    ToolTip.Tip="Decrease speed"/>
                            <Button Grid.Column="1" x:Name="Speed1xBtn"
                                    Content="1×"  Click="Speed1x_Click"
                                    Classes="SpeedBtnActive"
                                    Margin="3,0,0,0"
                                    ToolTip.Tip="Real time"/>
                            <Button Grid.Column="2" x:Name="Speed10xBtn"
                                    Content="10×" Click="Speed60x_Click"
                                    Classes="SpeedBtn"
                                    Margin="3,0,0,0"
                                    ToolTip.Tip="10× speed"/>
                            <Button Grid.Column="3" x:Name="Speed60xBtn"
                                    Content="60×" Click="Speed60x_Click"
                                    Classes="SpeedBtn"
                                    Margin="3,0,0,0"
                                    ToolTip.Tip="60× speed"/>
                            <Button Grid.Column="4"
                                    Content="»"  Click="SpeedUp_Click"
                                    Classes="SpeedBtn"
                                    ToolTip.Tip="Increase speed"
                                    Margin="3,0,0,0"/>
                        </Grid>

                        <!-- Pause / Resume button -->
                        <Button x:Name="PauseButton"
                                Click="Pause_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="{DynamicResource AtcSurface2}"
                                Foreground="{DynamicResource AtcWarning}"
                                BorderBrush="{DynamicResource AtcWarningDim}"
                                BorderThickness="1" CornerRadius="6"
                                FontWeight="Bold" FontSize="11"
                                Padding="10,11">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="PauseIcon" Text="⏸" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PauseLabel" Text="PAUSE SIMULATION" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Height="1"
                            Background="{DynamicResource AtcBorderSubtle}"
                            Margin="12,16,12,0"/>

                    <!-- ── Map overlays ───────────────────────────────── -->
                    <StackPanel Margin="12,14,12,0" Spacing="2">
                        <TextBlock Classes="SectionLabel" Text="MAP OVERLAYS" Margin="2,0,0,6"/>

                        <!-- Radar View -->
                        <Button x:Name="ToggleRadarButton"
                                Click="ToggleRadar_Click"
                                Classes="SidebarBtn">
                            <Grid ColumnDefinitions="4,30,*,Auto">
                                <Border Grid.Column="0"
                                        Width="3" Height="16" CornerRadius="2"
                                        Background="{DynamicResource AtcStripeRadar}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="📡"
                                           FontSize="13" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Radar View"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" x:Name="RadarActiveDot"
                                        Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AtcTextMuted}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Flight Queue -->
                        <Button x:Name="ToggleQueueButton"
                                Click="ToggleQueue_Click"
                                Classes="SidebarBtn">
                            <Grid ColumnDefinitions="4,30,*,Auto">
                                <Border Grid.Column="0"
                                        Width="3" Height="16" CornerRadius="2"
                                        Background="{DynamicResource AtcStripeQueue}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="☰"
                                           FontSize="13" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Flight Queue"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" x:Name="QueueActiveDot"
                                        Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AtcTextMuted}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- System Alerts -->
                        <Button x:Name="ToggleAlertsButton"
                                Click="ToggleAlerts_Click"
                                Classes="SidebarBtn">
                            <Grid ColumnDefinitions="4,30,*,Auto">
                                <Border Grid.Column="0"
                                        Width="3" Height="16" CornerRadius="2"
                                        Background="{DynamicResource AtcStripeAlerts}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="🔔"
                                           FontSize="13" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="System Alerts"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" x:Name="AlertsActiveDot"
                                        Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AtcTextMuted}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Live Dashboard -->
                        <Button x:Name="ToggleDashboardButton"
                                Click="ToggleDashboard_Click"
                                Classes="SidebarBtn">
                            <Grid ColumnDefinitions="4,30,*,Auto">
                                <Border Grid.Column="0"
                                        Width="3" Height="16" CornerRadius="2"
                                        Background="{DynamicResource AtcStripeDashboard}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="📊"
                                           FontSize="13" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Live Dashboard"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" x:Name="DashActiveDot"
                                        Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AtcTextMuted}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Border Height="1"
                            Background="{DynamicResource AtcBorderSubtle}"
                            Margin="12,14,12,0"/>

                    <!-- ── Environment controls ───────────────────────── -->
                    <StackPanel Margin="12,14,12,0" Spacing="8">
                        <TextBlock Classes="SectionLabel" Text="ENVIRONMENT" Margin="2,0,0,2"/>

                        <Button Content="🌤  Refresh Weather"
                                Click="Weather_Click"
                                Classes="SidebarBtn"
                                FontSize="12"/>

                        <!-- RVR override slider -->
                        <Border Background="{DynamicResource AtcSurface1}"
                                BorderBrush="{DynamicResource AtcBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="7" Padding="12,10">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Classes="SectionLabel"
                                               Text="MANUAL RVR OVERRIDE"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource AtcSurface3}"
                                            CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="RvrSliderLabel"
                                                   Text="10000 m"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource AtcPrimary}"/>
                                    </Border>
                                </Grid>
                                <Slider x:Name="RvrSlider"
                                        Minimum="50" Maximum="10000" Value="10000"
                                        TickFrequency="50" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Emergency control ──────────────────────────── -->
                    <Border Margin="12,20,12,0"
                            Background="{DynamicResource AtcDangerDim}"
                            BorderBrush="{DynamicResource AtcDanger}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,12">
                        <StackPanel Spacing="8">

                            <!-- Pulsing header -->
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource AtcDanger}"
                                        VerticalAlignment="Center">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.2" IterationCount="Infinite" PlaybackDirection="Alternate">
                                                    <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.15"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                                <TextBlock Text="EMERGENCY CONTROL"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcDanger}"
                                           LetterSpacing="2"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button Content="🚨  DECLARE EMERGENCY"
                                    Click="Emergency_Click"
                                    Background="{DynamicResource AtcDanger}"
                                    Foreground="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontWeight="Black" FontSize="11"
                                    Padding="10,11"
                                    LetterSpacing="1"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 1 — MAIN CANVAS + FLOATING PANELS                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="0"
                Background="{DynamicResource AtcBackground}"
                ClipToBounds="True">
            <Grid>

                <!-- Radar ring decorations -->
                <Border BorderBrush="{DynamicResource AtcRadarRing}" BorderThickness="1"
                        CornerRadius="1000" Opacity="0.20"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="360" Height="360"/>
                <Border BorderBrush="{DynamicResource AtcRadarRing}" BorderThickness="1"
                        CornerRadius="1000" Opacity="0.13"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="720" Height="720"/>
                <Border BorderBrush="{DynamicResource AtcRadarRing}" BorderThickness="1"
                        CornerRadius="1000" Opacity="0.07"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="1080" Height="1080"/>

                <!-- Crosshair lines -->
                <Border Width="1" Background="{DynamicResource AtcRadarGrid}"
                        Opacity="0.18"
                        HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
                <Border Height="1" Background="{DynamicResource AtcRadarGrid}"
                        Opacity="0.18"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

                <!-- Airport canvas -->
                <rendering:AirportCanvas x:Name="SimCanvas"/>

                <!-- Scanline texture overlay -->
                <Border Background="{DynamicResource AtcScanline}"
                        IsHitTestVisible="False"/>

                <!-- ── ALERT PANEL — top-right ─────────────────────── -->
                <Border x:Name="AlertPanel"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,16,0"
                        Width="320" MaxHeight="340"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto,*">

                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Classes="PanelHeader"
                                           Text="SYSTEM ALERTS"/>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AtcDangerDim}"
                                        BorderBrush="{DynamicResource AtcDanger}"
                                        BorderThickness="1"
                                        CornerRadius="10" Padding="7,2"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="AlertCountBadge"
                                               Text="0"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcDanger}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        x:Name="ClearAlertsButton"
                                        Content="✕"
                                        Classes="PanelClose"
                                        Click="ClearAlerts_Click"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      x:Name="AlertScroller"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AlertList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1"
                                                BorderBrush="{DynamicResource AtcBorderFaint}">
                                            <Grid ColumnDefinitions="3,*">
                                                <Border Grid.Column="0"
                                                        Width="3"
                                                        Background="{DynamicResource AtcDanger}"
                                                        x:Name="AlertStripe"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AtcTextData}"
                                                           TextWrapping="Wrap"
                                                           Padding="10,8,10,8"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── QUEUE PANEL — top-left ──────────────────────── -->
                <Border x:Name="QueuePanel"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="16,16,0,0"
                        Width="270" MaxHeight="380"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto,*">

                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Classes="PanelHeader"
                                           Text="FLIGHT QUEUE"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal" Spacing="10"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{DynamicResource AtcSuccess}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="ARR" FontSize="9"
                                                   Foreground="{DynamicResource AtcTextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{DynamicResource AtcPrimary}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="DEP" FontSize="9"
                                                   Foreground="{DynamicResource AtcTextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="QueueList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1"
                                                BorderBrush="{DynamicResource AtcBorderFaint}">
                                            <Grid ColumnDefinitions="3,*">
                                                <Border Grid.Column="0"
                                                        Width="3"
                                                        Background="{DynamicResource AtcSuccess}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AtcTextData}"
                                                           Padding="10,8,10,8"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ── EMERGENCY BANNER — center top ──────────────── -->
                <Border x:Name="EmergencyBanner"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,14,0,0"
                        Padding="32,12"
                        Background="{DynamicResource AtcDangerDim}"
                        BorderBrush="{DynamicResource AtcDanger}"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="14"
                                VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="{DynamicResource AtcDanger}"
                                VerticalAlignment="Center">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.8" IterationCount="Infinite" PlaybackDirection="Alternate">
                                            <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.1"/></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Border.Styles>
                        </Border>
                        <TextBlock x:Name="EmergencyText"
                                   Text="🚨  EMERGENCY DECLARED — MAYDAY"
                                   FontSize="13" FontWeight="Black"
                                   Foreground="{DynamicResource AtcDanger}"
                                   LetterSpacing="1.5"
                                   VerticalAlignment="Center"/>
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="{DynamicResource AtcDanger}"
                                VerticalAlignment="Center">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.8" IterationCount="Infinite" PlaybackDirection="Alternate">
                                            <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.1"/></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Border.Styles>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── AIRCRAFT INFO PANEL — bottom-left ──────────── -->
                <Border x:Name="AircraftInfoPanel"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="16,0,0,16"
                        Width="270"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto,Auto">

                        <!-- Header: callsign + phase pill -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,11">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock x:Name="InfoFlightId"
                                           Grid.Column="0"
                                           Text="—"
                                           FontSize="17" FontWeight="Black"
                                           Foreground="{DynamicResource AtcSuccess}"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        x:Name="InfoPhasePill"
                                        Background="{DynamicResource AtcInfoDim}"
                                        BorderBrush="{DynamicResource AtcInfo}"
                                        BorderThickness="1"
                                        CornerRadius="10" Padding="9,3"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="InfoPhase"
                                               Text="—"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcInfo}"
                                               LetterSpacing="1"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Data rows -->
                        <StackPanel Grid.Row="1"
                                    Margin="14,10,14,14"
                                    Spacing="8">

                            <Grid ColumnDefinitions="*,*">
                                <TextBlock Text="TYPE"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoType" Grid.Column="1"
                                           Text="—" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextData}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderFaint}"/>

                            <Grid ColumnDefinitions="*,*">
                                <TextBlock Text="ALTITUDE"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoAlt" Grid.Column="1"
                                           Text="—" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextData}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderFaint}"/>

                            <Grid ColumnDefinitions="*,*">
                                <TextBlock Text="SPEED"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoSpeed" Grid.Column="1"
                                           Text="—" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextData}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AtcBorderFaint}"/>

                            <Grid ColumnDefinitions="*,*">
                                <TextBlock Text="GATE"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource AtcTextMuted}"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoGate" Grid.Column="1"
                                           Text="—" FontSize="13" FontWeight="Black"
                                           Foreground="{DynamicResource AtcPrimary}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── DASHBOARD PANEL — bottom-right ─────────────── -->
                <Border x:Name="DashboardPanel"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,16,16"
                        Width="370"
                        Background="{DynamicResource AtcGlass}"
                        BorderBrush="{DynamicResource AtcBorderLine}"
                        BorderThickness="1" CornerRadius="10"
                        IsVisible="False">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AtcGlassDark}"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Classes="PanelHeader"
                                           Text="LIVE STATS DASHBOARD"/>
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Classes="PanelClose"
                                        Click="ToggleDashboard_Click"/>
                            </Grid>
                        </Border>

                        <!-- Traffic graph -->
                        <Border Grid.Row="1"
                                Padding="14,12,14,10"
                                BorderBrush="{DynamicResource AtcBorderFaint}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel"
                                           Text="TRAFFIC VOLUME — LAST 10 MIN"/>
                                <Border Background="{DynamicResource AtcSurface1}"
                                        BorderBrush="{DynamicResource AtcBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="4" Padding="3">
                                    <Canvas x:Name="TrafficGraphCanvas"
                                            Height="65"
                                            ClipToBounds="True"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Go-arounds by weather -->
                        <Border Grid.Row="2"
                                Padding="14,10,14,10"
                                BorderBrush="{DynamicResource AtcBorderFaint}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel"
                                           Text="GO-AROUNDS BY WEATHER"/>
                                <ItemsControl x:Name="GoAroundList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AtcTextSub}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource AtcAccent}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Runway utilization -->
                        <Border Grid.Row="3" Padding="14,10,14,16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="SectionLabel"
                                           Text="RUNWAY UTILIZATION"/>

                                <!-- 28L Arrivals -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="28L  ARRIVALS"
                                               FontSize="10"
                                               Foreground="{DynamicResource AtcTextSub}"/>
                                    <TextBlock x:Name="Rwy0Pct" Grid.Column="1"
                                               Text="0%"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcRunwayArrival}"/>
                                </Grid>
                                <Border Height="7" CornerRadius="4"
                                        Background="{DynamicResource AtcSurface2}">
                                    <Border x:Name="Rwy0Bar"
                                            HorizontalAlignment="Left"
                                            Height="7" Width="0" CornerRadius="4"
                                            Background="{DynamicResource AtcRunwayArrival}"/>
                                </Border>

                                <!-- 28R Departures -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                    <TextBlock Grid.Column="0"
                                               Text="28R  DEPARTURES"
                                               FontSize="10"
                                               Foreground="{DynamicResource AtcTextSub}"/>
                                    <TextBlock x:Name="Rwy1Pct" Grid.Column="1"
                                               Text="0%"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource AtcRunwayDeparture}"/>
                                </Grid>
                                <Border Height="7" CornerRadius="4"
                                        Background="{DynamicResource AtcSurface2}">
                                    <Border x:Name="Rwy1Bar"
                                            HorizontalAlignment="Left"
                                            Height="7" Width="0" CornerRadius="4"
                                            Background="{DynamicResource AtcRunwayDeparture}"/>
                                </Border>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM STATUS BAR                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource AtcSurface0}"
                BorderBrush="{DynamicResource AtcBorderLine}"
                BorderThickness="0,1,0,0"
                Padding="14,6">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Left — status chips -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal" Spacing="5"
                            VerticalAlignment="Center">

                    <!-- 28L -->
                    <Border Classes="StatusChip"
                            BorderBrush="{DynamicResource AtcRunwayArrival}"
                            BorderThickness="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border x:Name="Rwy28LDot"
                                    Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AtcRunwayArrival}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="28L"
                                       FontSize="10" FontWeight="Black"
                                       Foreground="{DynamicResource AtcTextSub}"
                                       VerticalAlignment="Center"
                                       LetterSpacing="0.5"/>
                            <TextBlock x:Name="Rwy28LStatus"
                                       Text="CLEAR"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcRunwayArrival}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 28R -->
                    <Border Classes="StatusChip"
                            BorderBrush="{DynamicResource AtcRunwayDeparture}"
                            BorderThickness="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border x:Name="Rwy28RDot"
                                    Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AtcRunwayDeparture}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="28R"
                                       FontSize="10" FontWeight="Black"
                                       Foreground="{DynamicResource AtcTextSub}"
                                       VerticalAlignment="Center"
                                       LetterSpacing="0.5"/>
                            <TextBlock x:Name="Rwy28RStatus"
                                       Text="CLEAR"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcRunwayDeparture}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Width="1" Height="14"
                            Background="{DynamicResource AtcBorderLine}"
                            VerticalAlignment="Center" Margin="2,0"/>

                    <!-- Active aircraft -->
                    <Border Classes="StatusChip">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="✈"
                                       FontSize="11"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipAircraft"
                                       Text="0"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="AC"
                                       FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Arrivals -->
                    <Border Classes="StatusChip"
                            BorderBrush="{DynamicResource AtcSuccess}"
                            BorderThickness="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↓"
                                       FontSize="12" FontWeight="Black"
                                       Foreground="{DynamicResource AtcSuccess}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipArrivals"
                                       Text="0"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="ARR"
                                       FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Departures -->
                    <Border Classes="StatusChip"
                            BorderBrush="{DynamicResource AtcPrimary}"
                            BorderThickness="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↑"
                                       FontSize="12" FontWeight="Black"
                                       Foreground="{DynamicResource AtcPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipDepartures"
                                       Text="0"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="DEP"
                                       FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Go-arounds -->
                    <Border Classes="StatusChip"
                            BorderBrush="{DynamicResource AtcWarning}"
                            BorderThickness="0,0,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="↩"
                                       FontSize="12" FontWeight="Black"
                                       Foreground="{DynamicResource AtcWarning}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChipGoArounds"
                                       Text="0"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AtcText}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="G/A"
                                       FontSize="9"
                                       Foreground="{DynamicResource AtcTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Right — server status + latency -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="LatencyText"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource AtcTextMuted}"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="12"
                            Background="{DynamicResource AtcBorderSubtle}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="SERVER"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource AtcTextMuted}"
                               LetterSpacing="1.5"
                               VerticalAlignment="Center"/>
                    <Border x:Name="ConnectionIndicator"
                            Width="8" Height="8" CornerRadius="4"
                            Background="{DynamicResource AtcTextMuted}"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Server connection status"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>