<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rendering="clr-namespace:AirportSim.Client.Rendering"
             x:Class="AirportSim.Client.Views.SimulationView">

    <UserControl.Styles>
        <Style Selector="Button.SidebarBtn">
            <Setter Property="Background" Value="#1E2A38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Button.SidebarBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A4A"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="260, *" RowDefinitions="*, Auto">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 0 — Sidebar Navigation & Controls                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="#131720"
                BorderBrush="#252B36"
                BorderThickness="0,0,1,0"
                Padding="16,20">
            <StackPanel Spacing="12">
                
                <!-- Branding Header -->
                <TextBlock Text="ATC TERMINAL" FontSize="18" FontWeight="Black" Foreground="{DynamicResource AtcPrimary}" LetterSpacing="2"/>
                <TextBlock Text="SIMULATION SYSTEM" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" Margin="0,-8,0,16"/>

                <!-- Time & Weather Widget -->
                <Border Background="#0A0D12" CornerRadius="8" Padding="12" BorderBrush="#252B36" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LOCAL TIME" FontSize="10" Foreground="{DynamicResource AtcTextMuted}"/>
                        <TextBlock x:Name="TimeText" Foreground="#FFFFFF" FontSize="24" FontWeight="Bold" Margin="0,2,0,8"/>
                        <TextBlock x:Name="WeatherText" Foreground="{DynamicResource AtcPrimary}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Height="1" Background="#252B36" Margin="0,8"/>

                <!-- Playback Controls -->
                <TextBlock Text="PLAYBACK SPEED" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" FontWeight="Bold"/>
                <Grid ColumnDefinitions="*,*,*,*">
                    <Button Grid.Column="0" Content="«" Click="SpeedDown_Click" Classes="SidebarBtn" ToolTip.Tip="Speed Down" Margin="0,0,2,0"/>
                    <Button Grid.Column="1" Content="1×" Click="Speed1x_Click" Classes="SidebarBtn" Margin="2,0"/>
                    <Button Grid.Column="2" Content="60×" Click="Speed60x_Click" Classes="SidebarBtn" Margin="2,0"/>
                    <Button Grid.Column="3" Content="»" Click="SpeedUp_Click" Classes="SidebarBtn" ToolTip.Tip="Speed Up" Margin="2,0,0,0"/>
                </Grid>
                
                <Button x:Name="PauseButton" Content="⏸ PAUSE SIMULATION" Click="Pause_Click" 
                        Background="#283545" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10,8"/>

                <Border Height="1" Background="#252B36" Margin="0,8"/>

                <!-- Overlays -->
                <TextBlock Text="MAP OVERLAYS" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" FontWeight="Bold"/>
                <Button x:Name="ToggleRadarButton" Content="📡 Radar View" Click="ToggleRadar_Click" Classes="SidebarBtn"/>
                <Button x:Name="ToggleQueueButton" Content="☰ Flight Queue" Click="ToggleQueue_Click" Classes="SidebarBtn"/>
                <Button x:Name="ToggleAlertsButton" Content="🔔 System Alerts" Click="ToggleAlerts_Click" Classes="SidebarBtn"/>
                <Button x:Name="ToggleDashboardButton" Content="📊 Live Dashboard" Click="ToggleDashboard_Click" Classes="SidebarBtn"/>

                <Border Height="1" Background="#252B36" Margin="0,8"/>

                <!-- Environmental Controls -->
                <Button Content="🌤 Refresh Weather" Click="Weather_Click" Classes="SidebarBtn"/>
                <Button Content="🚨 TRIGGER EMERGENCY" Click="Emergency_Click"
                        Background="#4A1010" Foreground="#FF5555" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10,12" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN 1 — Main Canvas & Floating Panels                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="0">

            <!-- Simulation canvas (bottom layer) -->
            <rendering:AirportCanvas x:Name="SimCanvas" />

            <!-- ── Alert panel (top-right overlay) ── -->
            <Border x:Name="AlertPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,16,16,0"
                    Width="300"
                    MaxHeight="250"
                    Background="{DynamicResource AtcGlass}"
                    BorderBrush="{DynamicResource AtcBorderLine}"
                    BorderThickness="1"
                    CornerRadius="8"
                    IsVisible="False">
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="#33000000" CornerRadius="8,8,0,0" Padding="12,8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="SYSTEM ALERTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AtcPrimary}" LetterSpacing="1.5" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="ClearAlertsButton" Content="✕" FontSize="12" Foreground="{DynamicResource AtcTextMuted}" Background="Transparent" BorderThickness="0" Padding="4,0" Click="ClearAlerts_Click"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" x:Name="AlertScroller" VerticalScrollBarVisibility="Auto" Padding="0,4">
                        <ItemsControl x:Name="AlertList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#1AFFFFFF">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="White" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Queue panel (top-left overlay) ── -->
            <Border x:Name="QueuePanel"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="16,16,0,0"
                    Width="240"
                    Background="{DynamicResource AtcGlass}"
                    BorderBrush="{DynamicResource AtcBorderLine}"
                    BorderThickness="1"
                    CornerRadius="8"
                    IsVisible="False">
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="#33000000" CornerRadius="8,8,0,0" Padding="12,8">
                        <TextBlock Text="NEXT FLIGHTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AtcPrimary}" LetterSpacing="1.5"/>
                    </Border>
                    <ItemsControl Grid.Row="1" x:Name="QueueList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#1AFFFFFF">
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="White" FontFamily="Consolas"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ── Emergency banner (centre top) ── -->
            <Border x:Name="EmergencyBanner"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,16,0,0"
                    Padding="24,10"
                    Background="#D9D32F2F"
                    CornerRadius="8"
                    IsVisible="False">
                <TextBlock x:Name="EmergencyText" FontSize="14" FontWeight="Bold" Foreground="White" Text="🚨 EMERGENCY DETECTED" HorizontalAlignment="Center"/>
            </Border>

            <!-- ── Aircraft Info Popover (bottom-left overlay) ── -->
            <Border x:Name="AircraftInfoPanel"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="16,0,0,16"
                    Width="240"
                    Background="{DynamicResource AtcGlass}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AtcBorderLine}"
                    CornerRadius="8"
                    IsVisible="False">
                <Grid RowDefinitions="Auto, Auto">
                    <Border Grid.Row="0" Background="#33000000" CornerRadius="8,8,0,0" Padding="12,8">
                        <TextBlock x:Name="InfoFlightId" Text="FLIGHT ID" FontSize="15" FontWeight="Bold" Foreground="#4CAF50"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="12,12,12,16" Spacing="8">
                        <Grid ColumnDefinitions="*, *"><TextBlock Text="TYPE:" FontSize="11" Foreground="{DynamicResource AtcTextMuted}"/><TextBlock x:Name="InfoType" Grid.Column="1" Text="-" FontSize="12" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                        <Grid ColumnDefinitions="*, *"><TextBlock Text="PHASE:" FontSize="11" Foreground="{DynamicResource AtcTextMuted}"/><TextBlock x:Name="InfoPhase" Grid.Column="1" Text="-" FontSize="12" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                        <Grid ColumnDefinitions="*, *"><TextBlock Text="ALTITUDE:" FontSize="11" Foreground="{DynamicResource AtcTextMuted}"/><TextBlock x:Name="InfoAlt" Grid.Column="1" Text="-" FontSize="12" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                        <Grid ColumnDefinitions="*, *"><TextBlock Text="SPEED:" FontSize="11" Foreground="{DynamicResource AtcTextMuted}"/><TextBlock x:Name="InfoSpeed" Grid.Column="1" Text="-" FontSize="12" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                        <Grid ColumnDefinitions="*, *"><TextBlock Text="GATE:" FontSize="11" Foreground="{DynamicResource AtcTextMuted}"/><TextBlock x:Name="InfoGate" Grid.Column="1" Text="-" FontSize="12" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Stats Dashboard panel (bottom-right overlay) ── -->
            <Border x:Name="DashboardPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    Width="360"
                    Background="{DynamicResource AtcGlass}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AtcBorderLine}"
                    CornerRadius="8"
                    IsVisible="False">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                    <Border Grid.Row="0" Background="#33000000" CornerRadius="8,8,0,0" Padding="12,8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="LIVE STATS DASHBOARD" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AtcPrimary}" LetterSpacing="1.5" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="{DynamicResource AtcTextMuted}" Background="Transparent" BorderThickness="0" Padding="4,0" Click="ToggleDashboard_Click"/>
                        </Grid>
                    </Border>
                    <!-- Traffic graph -->
                    <Border Grid.Row="1" Padding="12,12,12,6">
                        <Grid RowDefinitions="Auto, Auto">
                            <TextBlock Grid.Row="0" Text="TRAFFIC VOLUME (LAST 10 MIN)" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Canvas x:Name="TrafficGraphCanvas" Grid.Row="1" Height="65" Background="#1A000000" ClipToBounds="True"/>
                        </Grid>
                    </Border>
                    <!-- Go-around rate -->
                    <Border Grid.Row="2" Padding="12,6,12,6" BorderThickness="0,1,0,1" BorderBrush="#1AFFFFFF">
                        <Grid RowDefinitions="Auto, Auto">
                            <TextBlock Grid.Row="0" Text="GO-AROUNDS BY WEATHER" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="GoAroundList" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Foreground="White"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" Foreground="{DynamicResource AtcAccent}" FontFamily="Consolas" FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <!-- Runway meters -->
                    <Border Grid.Row="3" Padding="12,8,12,16">
                        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                            <TextBlock Grid.Row="0" Text="RUNWAY UTILIZATION" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="28L ARRIVALS" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <Border Grid.Row="2" Height="10" CornerRadius="5" Background="#1AFFFFFF" Margin="0,0,0,10">
                                <Border x:Name="Rwy0Bar" HorizontalAlignment="Left" Height="10" Width="0" CornerRadius="5" Background="#FF4CAF50"/>
                            </Border>
                            <TextBlock Grid.Row="3" Text="28R DEPARTURES" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <Border Grid.Row="4" Height="10" CornerRadius="5" Background="#1AFFFFFF">
                                <Border x:Name="Rwy1Bar" HorizontalAlignment="Left" Height="10" Width="0" CornerRadius="5" Background="{DynamicResource AtcPrimary}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM STATUS BAR                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0D1016"
                BorderBrush="#252B36"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <!-- Only minor readouts are kept down here now to keep the UI clean -->
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="RunwayText" Foreground="{DynamicResource AtcTextMuted}" FontSize="12"/>
                    <TextBlock x:Name="StatsText" Foreground="{DynamicResource AtcTextMuted}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="SERVER STATUS" FontSize="10" Foreground="{DynamicResource AtcTextMuted}" VerticalAlignment="Center"/>
                        <Border x:Name="ConnectionIndicator" Width="8" Height="8" CornerRadius="4" Background="Gray" ToolTip.Tip="Server connection"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>