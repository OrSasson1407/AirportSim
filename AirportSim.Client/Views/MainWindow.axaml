<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AirportSim.Client.Views"
        x:Class="AirportSim.Client.Views.MainWindow"
        Title="ATC Terminal — Airport Simulation"
        Width="1400"
        Height="800"
        MinWidth="1100"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AtcBackground}"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="False"
        Icon="avares://AirportSim.Client/app.manifest">

    <views:SimulationView x:Name="MainSimView" />

</Window>