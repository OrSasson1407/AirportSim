<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AirportSim.Client.Views"
        x:Class="AirportSim.Client.Views.MainWindow"
        Title="Airport ATC Simulator"
        Width="1280"
        Height="720"
        MinWidth="900"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="#0A0C14">

    <views:SimulationView x:Name="MainSimView" />

</Window>