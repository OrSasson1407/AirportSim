<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AirportSim.Client.Views"
        x:Class="AirportSim.Client.Views.MainWindow"
        Title="Airport ATC Simulator"
        Width="1366"
        Height="768"
        MinWidth="1024"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AtcBackground}">

    <views:SimulationView x:Name="MainSimView" />

</Window>