<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AirportSim.Client.Views"
        x:Class="AirportSim.Client.Views.MainWindow"
        Title="ATC Terminal — Airport Simulation"
        Width="1400"
        Height="800"
        MinWidth="1100"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AtcBackground}"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

    <Grid>
        <!-- Main Application Layout -->
        <Grid RowDefinitions="40, *">
            <!-- Custom Title Bar (HitTestVisible=False allows OS dragging) -->
            <Grid Grid.Row="0" Background="{DynamicResource AtcSidebar}" IsHitTestVisible="False">
                <TextBlock Text="✈ ATC TERMINAL DASHBOARD" 
                           Foreground="{DynamicResource AtcPrimary}" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           Margin="16,0,0,0"
                           LetterSpacing="1.5"/>
            </Grid>
            
            <!-- Your Simulation View -->
            <views:SimulationView x:Name="MainSimView" Grid.Row="1" />
        </Grid>

        <!-- Startup Splash Screen Overlay -->
        <Border x:Name="SplashOverlay" Background="{DynamicResource AtcBackground}" ZIndex="999">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                
                <TextBlock Text="✈" FontSize="72" Foreground="{DynamicResource AtcPrimary}" HorizontalAlignment="Center">
                    <TextBlock.Styles>
                        <!-- Simple pulsing animation for the splash icon -->
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="Infinite" PlaybackDirection="Alternate">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>

                <TextBlock Text="ATC TERMINAL SETUP" 
                           FontSize="22" FontWeight="Black"
                           Foreground="{DynamicResource AtcText}" 
                           HorizontalAlignment="Center"
                           LetterSpacing="3"/>

                <!-- Airport Layout Selector -->
                <StackPanel Spacing="8" Margin="0,12,0,0">
                    <TextBlock Text="SELECT AIRPORT LAYOUT"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource AtcTextMuted}"
                               LetterSpacing="1.5"
                               HorizontalAlignment="Center"/>
                    <ComboBox x:Name="AirportSelector"
                              Width="280"
                              SelectedIndex="0"
                              Background="{DynamicResource AtcSurface1}"
                              Foreground="{DynamicResource AtcText}"
                              BorderBrush="{DynamicResource AtcBorderLine}"
                              BorderThickness="1"
                              CornerRadius="6"
                              HorizontalAlignment="Center">
                        <ComboBoxItem Content="TLV — Ben Gurion (Default)"/>
                        <ComboBoxItem Content="LHR — London Heathrow"/>
                        <ComboBoxItem Content="JFK — John F. Kennedy"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="StartSimButton"
                        Content="CONNECT TO RADAR"
                        Click="StartSim_Click"
                        Background="{DynamicResource AtcPrimary}"
                        Foreground="{DynamicResource AtcBackground}"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="0,14"
                        Width="280"
                        HorizontalContentAlignment="Center"
                        CornerRadius="6"
                        Margin="0,16,0,0"/>

            </StackPanel>
        </Border>
    </Grid>

</Window>