<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AirportSim.Client.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <!-- ── Button Hover & Press Animations ────────────────────────────────────── -->
        <Style Selector="Button">
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.03)" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)" />
        </Style>

        <!-- ── Custom Modern ScrollBar ────────────────────────────────────────────── -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="8" />
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="8" />
        </Style>
        
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AtcTextMuted}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AtcPrimary}" />
        </Style>
    </Application.Styles>

    <!-- ═══════════════════════════════════════════════════════════════════
         ATC TERMINAL — GLOBAL DESIGN SYSTEM  (v2 — final)
    ═══════════════════════════════════════════════════════════════════ -->
    <Application.Resources>

        <!-- ── Base backgrounds ──────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcBackground">#080B10</SolidColorBrush>
        <SolidColorBrush x:Key="AtcSidebar">#0D1119</SolidColorBrush>

        <!-- ── Surface hierarchy ─────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcSurface0">#070A0F</SolidColorBrush>
        <SolidColorBrush x:Key="AtcSurface1">#111620</SolidColorBrush>
        <SolidColorBrush x:Key="AtcSurface2">#151B27</SolidColorBrush>
        <SolidColorBrush x:Key="AtcSurface3">#1C2535</SolidColorBrush>

        <!-- ── Glass overlays ────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcGlass">#E0111620</SolidColorBrush>
        <SolidColorBrush x:Key="AtcGlassLight">#BB151B27</SolidColorBrush>
        <SolidColorBrush x:Key="AtcGlassDark">#CC070A0F</SolidColorBrush>

        <!-- ── Brand colours ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcPrimary">#00D9F5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcPrimaryDim">#1A4A5A</SolidColorBrush>
        <SolidColorBrush x:Key="AtcAccent">#FFB020</SolidColorBrush>
        <SolidColorBrush x:Key="AtcAccentGlow">#FFCC60</SolidColorBrush>

        <!-- ── Text colours ──────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcText">#E8EDF5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcTextSub">#A0AEBF</SolidColorBrush>
        <SolidColorBrush x:Key="AtcTextMuted">#5A6A7A</SolidColorBrush>
        <SolidColorBrush x:Key="AtcTextDisabled">#2E3A4A</SolidColorBrush>

        <!-- ── Border colours ────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcBorderSubtle">#14FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="AtcBorderLine">#28FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="AtcBorderStrong">#4400D9F5</SolidColorBrush>

        <!-- ── Status colours ────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcSuccess">#22C55E</SolidColorBrush>
        <SolidColorBrush x:Key="AtcSuccessDim">#0D2B1A</SolidColorBrush>
        <SolidColorBrush x:Key="AtcWarning">#F59E0B</SolidColorBrush>
        <SolidColorBrush x:Key="AtcWarningDim">#2A1E06</SolidColorBrush>
        <SolidColorBrush x:Key="AtcDanger">#EF4444</SolidColorBrush>
        <SolidColorBrush x:Key="AtcDangerDim">#2D0A0A</SolidColorBrush>
        <SolidColorBrush x:Key="AtcInfo">#3B82F6</SolidColorBrush>
        <SolidColorBrush x:Key="AtcInfoDim">#0A1630</SolidColorBrush>

        <!-- ── Runway colours ────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcRunwayArrival">#22C55E</SolidColorBrush>
        <SolidColorBrush x:Key="AtcRunwayDeparture">#00D9F5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcRunwayOccupied">#EF4444</SolidColorBrush>

        <!-- ── Chart colours ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AtcGraphLine">#DC00D9F5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcGraphFill">#2800D9F5</SolidColorBrush>
        
        <!-- ── Radar Specific Additions ──────────────────────────────── -->
        <SolidColorBrush x:Key="AtcRadarGrid">#1A00D9F5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcRadarSweep">#3300D9F5</SolidColorBrush>
        <SolidColorBrush x:Key="AtcFlightPath">#8800D9F5</SolidColorBrush>

        <!-- ── Aircraft & UI Geometries ──────────────────────────────── -->
        <!-- Standard Commercial Jet (Top-Down) -->
        <StreamGeometry x:Key="AtcIconPlane">M21,16v-2l-8-5V3.5c0-0.83-0.67-1.5-1.5-1.5S10,2.67,10,3.5V9l-8,5v2l8-2.5V19l-2,1.5V22l3.5-1l3.5,1v-1.5L13,19v-5.5L21,16z</StreamGeometry>
        
        <!-- Emergency Alert Triangle -->
        <StreamGeometry x:Key="AtcIconAlert">M12,2L1,21H23M12,6L19.53,19H4.47M11,10V14H13V10M11,16V18H13V16</StreamGeometry>
        
        <!-- Target Reticle (Useful for Radar Selection) -->
        <StreamGeometry x:Key="AtcIconReticle">M12,2V4M12,20V22M2,12H4M20,12H22M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z</StreamGeometry>

    </Application.Resources>
</Application>