<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AirportSim.Client.App"
             RequestedThemeVariant="Dark">
             <!-- Forced to Dark mode for the ATC Radar visual style -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <!-- Global Design System Colors -->
    <Application.Resources>
        <SolidColorBrush x:Key="AtcBackground">#0B0E14</SolidColorBrush>
        <SolidColorBrush x:Key="AtcGlass">#CC11151E</SolidColorBrush>
        <SolidColorBrush x:Key="AtcPrimary">#00E5FF</SolidColorBrush>
        <SolidColorBrush x:Key="AtcAccent">#FFAB00</SolidColorBrush>
        <SolidColorBrush x:Key="AtcTextMuted">#8A9AAB</SolidColorBrush>
        <SolidColorBrush x:Key="AtcBorderLine">#33FFFFFF</SolidColorBrush>
    </Application.Resources>
</Application>